{
  "name": "web-browser-from-scratch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Educational TypeScript/Electron web browser built from scratch.",
  "main": "dist/main/main.cjs",
  "scripts": {
    "dev": "npm run build:main && concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config vite.renderer.config.ts --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "vite build --config vite.main.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "start": "electron .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "browser",
    "electron",
    "typescript",
    "education"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^42.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.6",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.4"
  }
}
